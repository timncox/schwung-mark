{
  "title": "Mark",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "5-track live looper",
        "in the style of the",
        "Boss RC-505.",
        "",
        "Each track records,",
        "plays and overdubs",
        "Move's input (mic,",
        "line or USB-C).",
        "",
        "Open it from the",
        "overtake menu",
        "(Shift+Vol+Jog).",
        "Back hides the UI;",
        "audio keeps going.",
        "Shift+Vol+Jog exits."
      ]
    },
    {
      "title": "Quick Start",
      "lines": [
        "1. Tap a top-row",
        " pad to record.",
        "2. Tap again to",
        " close the loop",
        " and play.",
        "3. Tap again to",
        " overdub layers.",
        "4. Repeat on the",
        " other tracks.",
        "",
        "Lengths snap to",
        "whole measures.",
        "Track 1 sets the",
        "grid; later tracks",
        "start in sync."
      ]
    },
    {
      "title": "Track pads",
      "lines": [
        "Columns 1-5 =",
        "tracks 1-5.",
        "",
        "Top row: record /",
        " play / overdub",
        " (red / green /",
        " yellow; white =",
        " stopped, dim =",
        " empty, blink =",
        " waiting for the",
        " measure).",
        "Row 2: stop; hold",
        " to clear.",
        "Row 3: reverse.",
        "Row 4: FX on/off;",
        " Shift+tap =",
        " one-shot.",
        "",
        "(Rows counted from",
        "the top.)"
      ]
    },
    {
      "title": "Right column",
      "lines": [
        "Top right corner:",
        "All start/stop,",
        "Undo / redo",
        " (orange = undo,",
        " cyan = redo),",
        "Monitor on/off.",
        "",
        "Row 2: Quantize,",
        "Rec then play or",
        "overdub, Dub mode",
        "(overdub/replace).",
        "Row 3: Play mode",
        "(multi/single),",
        "Sessions."
      ]
    },
    {
      "title": "Track FX",
      "lines": [
        "One insert per",
        "track: low pass,",
        "high pass, crush,",
        "delay (8th sync),",
        "phaser, ring mod.",
        "",
        "Bottom-row pad",
        "toggles it.",
        "Knob 7: FX type",
        "Knob 8: FX amount",
        "for the last track",
        "you touched.",
        "",
        "Full control in",
        "the web mixer."
      ]
    },
    {
      "title": "Sessions",
      "lines": [
        "Save loops + mixer",
        "to the Move, recall",
        "them anytime - the",
        "RC's 99 memories.",
        "",
        "Session pad (row 3,",
        "col 7): steps show",
        "16 slots. Green =",
        "saved, dim = empty.",
        "Tap = load, hold",
        "= save, Shift+tap",
        "= delete.",
        "",
        "Loading replaces",
        "current loops!",
        "Survives module",
        "updates + reboots."
      ]
    },
    {
      "title": "Loop length",
      "lines": [
        "The steps show the",
        "current track's",
        "length: one step =",
        "1/16 of a measure.",
        "",
        "TAP A STEP to set",
        "the length - step",
        "5 makes a 5/16",
        "loop churning",
        "against the drums.",
        "Tap a later step",
        "to get audio back.",
        "",
        "Arrows also trim",
        "by one grid unit.",
        "Audio is kept;",
        "trims survive",
        "sessions."
      ]
    },
    {
      "title": "Quantize",
      "lines": [
        "Quantize pad: tap",
        "= on / off.",
        "Shift+tap cycles",
        "the grid unit:",
        "measure (cyan),",
        "beat (blue),",
        "8th (purple),",
        "16th (orange).",
        "",
        "The grid rounds",
        "record lengths and",
        "schedules starts.",
        "Off = free length,",
        "instant fire."
      ]
    },
    {
      "title": "Single mode",
      "lines": [
        "Play-mode pad (row",
        "3, col 6): tracks",
        "become exclusive",
        "song sections -",
        "starting one stops",
        "the others, on the",
        "measure.",
        "",
        "Verse on T1,",
        "chorus on T2,",
        "bridge on T3:",
        "one pad per",
        "section."
      ]
    },
    {
      "title": "Knobs",
      "lines": [
        "Knobs 1-5: track",
        "levels (0-200).",
        "Knob 6: master.",
        "Knob 7: FX type.",
        "Knob 8: FX amount.",
        "Jog wheel: master.",
        "",
        "Hold Shift:",
        "1-5 track pans,",
        "6 monitor,",
        "7 transport follow,",
        "8 BPM override",
        " (49 = off)."
      ]
    },
    {
      "title": "Web mixer",
      "lines": [
        "Open move.local in",
        "a browser, Remote",
        "UI, Tool tab: full",
        "mixer with faders,",
        "pans, FX, modes,",
        "and session slots.",
        "",
        "Needs the schwung",
        "manager newer than",
        "v0.11.4 (Tool tab)."
      ]
    },
    {
      "title": "Sync",
      "lines": [
        "With Move's MIDI",
        "Clock set to Out,",
        "loops lock to the",
        "transport and set",
        "Setup > MIDI Sync.",
        "",
        "Without clock, the",
        "first loop defines",
        "the grid and all",
        "other tracks snap",
        "to it.",
        "",
        "Move keeps playing",
        "under Mark - use",
        "its tracks as the",
        "rhythm section."
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Undo removes the",
        "last overdub or",
        "recording; press",
        "again to redo.",
        "",
        "Reverse tracks",
        "cannot overdub",
        "(RC-505 rule).",
        "",
        "One-shot tracks",
        "play once and",
        "stop - good for",
        "phrases and hits.",
        "",
        "Presets save the",
        "mixer settings,",
        "not the audio."
      ]
    }
  ]
}
